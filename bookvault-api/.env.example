# ==================== APPLICATION ====================
NODE_ENV=development
PORT=3000

# ==================== DATABASE ====================
MONGODB_URI=mongodb://127.0.0.1:27017/bookstore-app-api

# ==================== JWT & TOKENS ====================
# Algorithm: HS256 (symmetric) or RS256 (asymmetric)
JWT_ALGORITHM=HS256
# Required for HS256; ignored if using RS256
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# Secret for hashing refresh tokens in storage
TOKEN_HASH_SECRET=change-me-token-hash-secret
# Token expiration times (format: 15m, 7d, 1h, etc.)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== COOKIES ====================
# Security settings
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/
# Cookie names
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token

# ==================== CSRF PROTECTION ====================
CSRF_HEADER_NAME=x-csrf-token

# ==================== PASSWORD SECURITY ====================
# Bcrypt cost factor (8-15; higher = slower but more secure)
BCRYPT_ROUNDS=12

# ==================== RATE LIMITING ====================
# Login endpoint limits
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_MAX=20
# Refresh endpoint limits
REFRESH_RATE_LIMIT_WINDOW_MINUTES=10
REFRESH_RATE_LIMIT_MAX=30

# ==================== ACCOUNT LOCKOUT ====================
# Failed login attempts before lockout
LOGIN_MAX_ATTEMPTS=5
# Initial lockout duration (exponentially increases)
LOGIN_LOCK_BASE_MINUTES=5
# Maximum lockout duration
LOGIN_LOCK_MAX_MINUTES=60

# ==================== TOKEN REUSE DETECTION ====================
# Revocation scope on token reuse: 'family' or 'user'
# 'family': revokes only the token family
# 'user': revokes all sessions for the user + bumps tokenVersion
REFRESH_REUSE_REVOKE_SCOPE=user
